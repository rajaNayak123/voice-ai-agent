# ---------------------------------------------------------------------------
# Server configuration
# ---------------------------------------------------------------------------
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Deepgram (Streaming STT + Aura Streaming TTS)
# Get a key at https://console.deepgram.com
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# STT model. nova-2 supports multilingual (incl. Hindi/code-switched) detection.
DEEPGRAM_STT_MODEL=nova-2
# "multi" enables Deepgram's multilingual code-switch detection (en/hi).
DEEPGRAM_STT_LANGUAGE=multi

# Aura TTS voice. aura-asteria-en is a natural English voice; swap per-language
# at runtime via the voice map in server/src/services/tts/voiceMap.ts
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ---------------------------------------------------------------------------
# Groq (LLM inference - Llama 3.1 8B, low latency streaming)
# Get a key at https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=400

# ---------------------------------------------------------------------------
# Embeddings (HuggingFace Inference API)
# Get a token at https://huggingface.co/settings/tokens
# Model: multilingual embedding model so Hindi/Hinglish/English all embed well
# ---------------------------------------------------------------------------
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HF_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# Qdrant Vector DB
# Run locally: docker run -p 6333:6333 qdrant/qdrant
# Or use Qdrant Cloud: https://cloud.qdrant.io
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=novadesk_kb

# ---------------------------------------------------------------------------
# RAG tuning
# ---------------------------------------------------------------------------
RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.45
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
